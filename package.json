{
  "name": "mdenc",
  "version": "0.1.0",
  "description": "Diff-friendly encrypted Markdown format",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "mdenc": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun x tsup",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "bun x tsc --noEmit"
  },
  "keywords": [
    "markdown",
    "encryption",
    "git",
    "diff-friendly",
    "aead"
  ],
  "license": "ISC",
  "dependencies": {
    "@noble/ciphers": "^1.2.1",
    "@noble/hashes": "^1.7.1",
    "hash-wasm": "^4.12.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "@types/bun": "^1.2.4"
  }
}
